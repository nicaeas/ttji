/* 天天记 · 全局样式 */
/* 设计调性：温暖纸张日记风格 */

page {
  --color-bg-primary: #F5F0E8;
  --color-bg-secondary: #FDFAF3;
  --color-bg-card: #FFFDF7;
  --color-bg-warm: #FEF9F0;
  
  --color-text-primary: #3D3226;
  --color-text-secondary: #8B7E74;
  --color-text-hint: #B8A99A;
  --color-text-inverse: #FDFAF3;
  
  --color-accent: #C4956A;
  --color-accent-light: #E8D5C4;
  --color-accent-dark: #8B5E3C;
  
  --color-success: #7B9B6A;
  --color-warning: #C49B4A;
  --color-danger: #C46A6A;
  --color-info: #6A8B9B;
  
  --color-mood-happy: #F0C060;
  --color-mood-calm: #7BA0A0;
  --color-mood-sad: #8B7BA0;
  --color-mood-excited: #C47B6A;
  --color-mood-grateful: #8BA07B;
  --color-mood-anxious: #A08B7B;
  
  --font-display: 'Georgia', 'Times New Roman', serif;
  --font-body: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  --font-mono: 'Courier New', 'Consolas', monospace;
  
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  
  --shadow-sm: 0 2rpx 8rpx rgba(61, 50, 38, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(61, 50, 38, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(61, 50, 38, 0.10);
  
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-family: var(--font-body);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* 通用样式 */
.container {
  min-height: 100vh;
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.card:active {
  box-shadow: var(--shadow-md);
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--color-accent);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--radius-md);
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-outline {
  background-color: transparent;
  color: var(--color-accent);
  border: 2rpx solid var(--color-accent);
  border-radius: var(--radius-md);
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.btn-ghost {
  background-color: transparent;
  color: var(--color-text-secondary);
  border: none;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
}

.btn-danger {
  background-color: var(--color-danger);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: var(--color-accent-light);
  margin: var(--spacing-md) 0;
}

.divider-dashed {
  height: 1rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--color-accent-light) 0,
    var(--color-accent-light) 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
  margin: var(--spacing-md) 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.empty-state-text {
  color: var(--color-text-hint);
  font-size: 28rpx;
  text-align: center;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background-color: var(--color-accent-light);
  color: var(--color-accent-dark);
}

.tag-sm {
  padding: 2rpx 12rpx;
  font-size: 20rpx;
}

/* 页头 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0 var(--spacing-md);
}

.page-title {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 12rpx 24rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
}

.search-bar input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.search-bar .search-icon {
  margin-right: var(--spacing-sm);
  font-size: 32rpx;
  color: var(--color-text-hint);
}

/* FAB 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
  box-shadow: 0 8rpx 24rpx rgba(139, 94, 60, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.fab:active {
  transform: scale(0.92);
  transition: transform 0.2s ease;
}

.fab-text {
  color: #fff;
  font-size: 48rpx;
  line-height: 1;
  margin-top: -4rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(61, 50, 38, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.25s ease;
}

.modal-content {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  width: 80vw;
  max-height: 70vh;
  animation: slideUp 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 文本截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.text-clamp-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
