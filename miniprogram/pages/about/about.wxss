/* pages/about/about.wxss */

.container {
  padding: var(--spacing-md);
  padding-bottom: 80rpx;
}

/* Hero */
.about-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.hero-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
}

.hero-title {
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
  font-style: italic;
}

.hero-version {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: var(--spacing-sm);
  padding: 4rpx 16rpx;
  background-color: var(--color-accent-light);
  border-radius: 20rpx;
}

/* 统计卡片 */
.stats-card {
  margin-bottom: var(--spacing-xl);
}

.stats-row {
  display: flex;
  align-items: center;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-accent-dark);
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

.stats-div {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-accent-light);
}

/* 功能列表 */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  display: block;
  padding-left: 4rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.feature-card {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-md);
  margin-bottom: 0;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-md);
  margin-top: 4rpx;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  line-height: 1.5;
  display: block;
}

/* 开发者卡片 */
.dev-card {
  padding: var(--spacing-md);
}

.dev-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
}

.dev-row + .dev-row {
  border-top: 1rpx solid #F0EDE5;
}

.dev-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.dev-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* 底部 */
.about-footer {
  text-align: center;
  padding: var(--spacing-xl) 0;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
  line-height: 1.8;
}
