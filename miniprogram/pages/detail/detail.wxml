<view class="container">
  <!-- ==================== 查看模式 ==================== -->
  <block wx:if="{{!isEditing && !isNew}}">
    <!-- 顶部操作栏 -->
    <view class="detail-toolbar">
      <view class="toolbar-left">
        <text class="toolbar-date">{{createdAtDisplay}}</text>
      </view>
      <view class="toolbar-right">
        <view class="tool-btn" bindtap="enterEditMode">
          <text>✏️ 编辑</text>
        </view>
        <view class="tool-btn tool-btn-danger" bindtap="toggleDeleteConfirm">
          <text>🗑️</text>
        </view>
      </view>
    </view>

    <!-- 心情和分类标签 -->
    <view class="detail-meta">
      <mood-icon mood="{{mood}}" size="md" />
      <view wx:if="{{categoryId}}" class="detail-category tag">
        <block wx:for="{{categoryOptions}}" wx:key="id">
          <text wx:if="{{item.id === categoryId}}">{{item.icon}} {{item.name}}</text>
        </block>
      </view>
    </view>

    <!-- 标题 -->
    <view wx:if="{{title}}" class="detail-title">{{title}}</view>

    <!-- Markdown 渲染内容 -->
    <view class="detail-content">
      <markdown-view content="{{content}}" />
    </view>

    <!-- 底部编辑时间 -->
    <view wx:if="{{updatedAt !== createdAt}}" class="detail-updated">
      <text>最后编辑于 {{updatedAt}}</text>
    </view>
  </block>

  <!-- ==================== 编辑模式 / 新建模式 ==================== -->
  <block wx:if="{{isEditing}}">
    <!-- 编辑工具栏 -->
    <view class="edit-toolbar">
      <view class="edit-toolbar-left">
        <view class="tool-btn" bindtap="cancelEdit">
          <text>取消</text>
        </view>
      </view>
      <view class="edit-toolbar-title">
        <text>{{isNew ? '写日记' : '编辑日记'}}</text>
      </view>
      <view class="edit-toolbar-right">
        <view class="tool-btn preview-toggle" bindtap="togglePreview">
          <text>{{previewMode ? '📝 编辑' : '👁️ 预览'}}</text>
        </view>
        <view class="btn-primary btn-save" bindtap="saveDiary">
          <text>保存</text>
        </view>
      </view>
    </view>

    <!-- 编辑模式下：显示编辑区域或预览 -->
    <block wx:if="{{!previewMode}}">
      <!-- 标题输入 -->
      <view class="edit-title-wrap">
        <input
          class="edit-title-input"
          placeholder="给日记起个标题..."
          placeholder-class="placeholder"
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="100"
        />
      </view>

      <!-- 元数据选择行 -->
      <view class="edit-meta-row">
        <view class="meta-item" bindtap="toggleMoodPicker">
          <mood-icon mood="{{mood}}" size="sm" />
          <text class="meta-arrow">▾</text>
        </view>
        <view class="meta-item" bindtap="toggleCategoryPicker">
          <block wx:for="{{categoryOptions}}" wx:key="id">
            <view wx:if="{{item.id === categoryId}}" class="tag tag-sm">
              {{item.icon}} {{item.name}}
            </view>
          </block>
          <view wx:if="{{!categoryId}}" class="tag tag-sm tag-placeholder">
            📂 选择分类
          </view>
          <text class="meta-arrow">▾</text>
        </view>
      </view>

      <!-- 心情选择面板 -->
      <view wx:if="{{showMoodPicker}}" class="inline-picker">
        <view class="picker-grid">
          <view
            wx:for="{{moodOptions}}"
            wx:key="id"
            class="picker-item {{mood === item.id ? 'picker-item-active' : ''}}"
            data-mood="{{item.id}}"
            bindtap="onSelectMood"
          >
            <text class="picker-emoji">{{item.emoji}}</text>
            <text class="picker-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 分类选择面板 -->
      <view wx:if="{{showCategoryPicker}}" class="inline-picker">
        <view
          wx:for="{{categoryOptions}}"
          wx:key="id"
          class="picker-row {{categoryId === item.id ? 'picker-row-active' : ''}}"
          data-catid="{{item.id}}"
          bindtap="onSelectCategory"
        >
          <text>{{item.icon}} {{item.name}}</text>
          <text wx:if="{{categoryId === item.id}}" class="picker-check">✓</text>
        </view>
      </view>

      <!-- Markdown 内容编辑器 -->
      <view class="edit-content-wrap">
        <view class="edit-content-hint">
          <text>支持 Markdown 语法：**粗体** *斜体* `代码` > 引用 ## 标题</text>
        </view>
        <textarea
          class="edit-content-textarea"
          placeholder="开始写日记...\n\n支持 Markdown 格式：\n## 标题\n**粗体** *斜体*\n- 列表项\n> 引用文字"
          placeholder-class="placeholder"
          value="{{content}}"
          bindinput="onContentInput"
          bindblur="onContentBlur"
          auto-height
          show-confirm-bar="{{false}}"
          adjust-position="{{true}}"
        />
      </view>
    </block>

    <!-- 预览模式 -->
    <block wx:if="{{previewMode}}">
      <view class="preview-banner">
        <text>📄 预览模式</text>
      </view>
      <view class="detail-title">{{title || '无标题'}}</view>
      <view class="detail-content">
        <markdown-view content="{{content}}" />
      </view>
    </block>
  </block>

  <!-- ==================== 删除确认 ==================== -->
  <view wx:if="{{showDeleteConfirm}}" class="modal-mask" bindtap="toggleDeleteConfirm">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">确认删除</view>
      <view class="modal-body">删除后无法恢复，确定要删除这篇日记吗？</view>
      <view class="modal-footer">
        <view class="btn-ghost" bindtap="toggleDeleteConfirm">取消</view>
        <view class="btn-danger" bindtap="confirmDelete">删除</view>
      </view>
    </view>
  </view>
</view>
