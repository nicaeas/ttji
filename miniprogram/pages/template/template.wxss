/* pages/template/template.wxss */

.container {
  padding: var(--spacing-md);
  padding-bottom: 60rpx;
}

.section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  padding: 0 4rpx;
}

.section-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.section-action {
  font-size: 26rpx;
  color: var(--color-accent);
  font-weight: 500;
  padding: 6rpx 16rpx;
  background-color: var(--color-accent-light);
  border-radius: var(--radius-md);
}

/* 模板卡片 */
.template-grid {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.template-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  margin-bottom: 0;
  transition: all 0.2s ease;
}

.template-card:active {
  transform: scale(0.98);
}

.tpl-icon {
  font-size: 48rpx;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.tpl-info {
  flex: 1;
  min-width: 0;
}

.tpl-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}

.tpl-desc {
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.tpl-arrow {
  font-size: 32rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
}

/* 自定义模板操作 */
.custom-card {
  padding-right: var(--spacing-sm);
}

.tpl-actions {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-left: var(--spacing-sm);
}

.tpl-action-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--color-bg-warm);
  font-size: 24rpx;
}

.tpl-delete {
  color: var(--color-danger);
}

/* 空状态 */
.empty-state-sm {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: var(--spacing-sm);
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* ========== 编辑器弹窗 ========== */
.template-editor {
  width: 88vw;
  max-height: 85vh;
  overflow-y: auto;
}

.editor-field {
  margin-bottom: var(--spacing-md);
}

.editor-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.editor-input {
  width: 100%;
  padding: var(--spacing-sm);
  border: 1rpx solid var(--color-accent-light);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
}

.editor-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--spacing-sm);
  border: 1rpx solid var(--color-accent-light);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  line-height: 1.6;
  font-family: var(--font-mono);
  box-sizing: border-box;
}

/* 图标选择 */
.icon-scroll {
  white-space: nowrap;
}

.icon-grid {
  display: flex;
  gap: 12rpx;
}

.icon-option {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-warm);
  font-size: 32rpx;
  transition: all 0.15s ease;
}

.icon-selected {
  background-color: var(--color-accent-light);
  box-shadow: 0 0 0 2rpx var(--color-accent);
}

/* 心情选择 */
.mood-scroll {
  white-space: nowrap;
}

.mood-grid {
  display: flex;
  gap: 12rpx;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-warm);
  min-width: 72rpx;
  transition: all 0.15s ease;
}

.mood-selected {
  background-color: var(--color-accent-light);
  box-shadow: 0 0 0 2rpx var(--color-accent);
}

.mood-emoji {
  font-size: 28rpx;
}

.mood-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 2rpx;
}

/* 编辑器底部 */
.editor-footer {
  display: flex;
  gap: var(--spacing-md);
  justify-content: flex-end;
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-accent-light);
}

.editor-footer .btn-primary {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
}
